{
  "name": "mit-web-catbook",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Catbook — a full-stack MERN social app built along the MIT Web Lab (weblab) curriculum: React + Express + MongoDB + Google-OAuth-style auth + Socket.io real-time.",
  "engines": {
    "node": ">=18"
  },
  "config": {
    "mongodbMemoryServer": {
      "downloadDir": "D:/devtools/mongodb-binaries"
    }
  },
  "scripts": {
    "start": "node server/server.js",
    "dev:server": "node server/server.js",
    "dev:client": "vite --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "preview": "vite preview --config client/vite.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "node scripts/smoke.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "mongoose": "^8.9.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "mongodb-memory-server": "^10.1.3",
    "supertest": "^7.0.0",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
