# Copy to .env to override defaults. All optional — the app boots with sensible
# local defaults and an in-memory MongoDB when these are unset.

# Port the Express + Socket.io server listens on.
PORT=3000

# MongoDB connection string. If unset, the server spins up an in-memory MongoDB
# (mongodb-memory-server) so the app runs with zero external services.
# MONGO_URI=mongodb://localhost:27017/catbook

# Session signing secret.
SESSION_SECRET=catbook-dev-secret-change-me

# Google OAuth client id (the real weblab uses @react-oauth/google). For local
# development the login is stubbed and this is not required.
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
